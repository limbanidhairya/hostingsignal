<div class="card" style="max-width: 600px; margin: 0 auto;">
    <h2>Create a New Account</h2>
    <p>Provision a new web hosting space on this server.</p>
    
    [% IF error %]
    <div style="background: #fee; color: #c00; padding: 10px; margin-bottom: 15px; border-radius: 3px;">
        <strong>Error:</strong> [% error %]
    </div>
    [% END %]
    
    [% IF success %]
    <div style="background: #efe; color: #090; padding: 10px; margin-bottom: 15px; border-radius: 3px;">
        <strong>Success:</strong> [% success %]
    </div>
    [% END %]
    
    <form method="POST" action="/cpsess[% session_id %]/scripts/command?action=create_account">
        <div style="margin-bottom: 15px;">
            <label style="display: block; font-weight: bold; margin-bottom: 5px;">Domain</label>
            <input type="text" name="domain" placeholder="example.com" style="width: 100%; padding: 8px;" required>
        </div>
        
        <div style="margin-bottom: 15px;">
            <label style="display: block; font-weight: bold; margin-bottom: 5px;">Username</label>
            <input type="text" name="user" placeholder="exampleu" style="width: 100%; padding: 8px;" required>
        </div>
        
        <div style="margin-bottom: 15px;">
            <label style="display: block; font-weight: bold; margin-bottom: 5px;">Password</label>
            <input type="password" name="pass" style="width: 100%; padding: 8px;" required>
        </div>
        
        <div style="margin-bottom: 15px;">
            <label style="display: block; font-weight: bold; margin-bottom: 5px;">Email</label>
            <input type="email" name="email" style="width: 100%; padding: 8px;" required>
        </div>
        
        <button type="submit" style="background: #f15a24; color: white; padding: 10px 20px; border: none; border-radius: 3px; cursor: pointer;">
            Create
        </button>
    </form>
</div>
