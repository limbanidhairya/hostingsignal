<div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-6">
    <div>
        <h1 class="text-2xl font-extrabold text-slate-900 dark:text-white">Settings</h1>
        <p class="text-slate-500 dark:text-slate-400 mt-1">Manage your account preferences and security</p>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    <div class="glass rounded-xl overflow-hidden flex flex-col">
        <div class="px-6 py-4 border-b border-border-dark">
            <h3 class="font-bold text-slate-100 flex items-center gap-2"><span class="material-symbols-outlined text-primary">person</span> Account Profile</h3>
        </div>
        <div class="p-6 flex-1">
            <form method="POST" action="/api/account/update_profile">
                <div class="mb-4">
                    <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Username</label>
                    <input type="text" class="w-full bg-slate-800/30 border border-slate-700/50 rounded-lg px-4 py-2.5 text-sm text-slate-400 focus:outline-none cursor-not-allowed" value="<TMPL_VAR NAME=user>" disabled>
                    <p class="text-[10px] text-slate-500 mt-1">Username cannot be changed.</p>
                </div>
                <div class="mb-6">
                    <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Contact Email</label>
                    <input type="email" name="contact_email" class="w-full bg-slate-800/50 border border-slate-700 rounded-lg px-4 py-2.5 text-sm text-slate-200 focus:ring-1 focus:ring-primary focus:border-primary transition-all outline-none" value="<TMPL_VAR NAME=contact_email>">
                </div>
                <button type="submit" class="py-2.5 px-6 bg-slate-800 text-white text-sm font-bold rounded-lg border border-slate-700 hover:bg-slate-700 transition-colors">Save Profile</button>
            </form>
        </div>
    </div>

    <div class="glass rounded-xl overflow-hidden flex flex-col">
        <div class="px-6 py-4 border-b border-border-dark">
            <h3 class="font-bold text-slate-100 flex items-center gap-2"><span class="material-symbols-outlined text-accent">security</span> Security</h3>
        </div>
        <div class="p-6 flex-1">
            <form method="POST" action="/api/account/change_password">
                <div class="mb-4">
                    <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Current Password</label>
                    <input type="password" name="current_password" class="w-full bg-slate-800/50 border border-slate-700 rounded-lg px-4 py-2.5 text-sm text-slate-200 focus:ring-1 focus:ring-primary focus:border-primary transition-all outline-none" required>
                </div>
                <div class="mb-4">
                    <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">New Password</label>
                    <input type="password" name="new_password" class="w-full bg-slate-800/50 border border-slate-700 rounded-lg px-4 py-2.5 text-sm text-slate-200 focus:ring-1 focus:ring-primary focus:border-primary transition-all outline-none" required>
                </div>
                <div class="mb-6">
                    <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Confirm New Password</label>
                    <input type="password" name="confirm_password" class="w-full bg-slate-800/50 border border-slate-700 rounded-lg px-4 py-2.5 text-sm text-slate-200 focus:ring-1 focus:ring-primary focus:border-primary transition-all outline-none" required>
                </div>
                <button type="submit" class="py-2.5 px-6 bg-primary text-white text-sm font-bold rounded-lg hover:bg-primary/90 transition-colors shadow-lg shadow-primary/20">Update Password</button>
            </form>
        </div>
    </div>
</div>
