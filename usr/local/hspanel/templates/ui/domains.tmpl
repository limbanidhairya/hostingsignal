<div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-6">
    <div>
        <h1 class="text-2xl font-extrabold text-slate-900 dark:text-white">Domains</h1>
        <p class="text-slate-500 dark:text-slate-400 mt-1">Manage your domains, subdomains, and redirects</p>
    </div>
    <button class="px-4 py-2 bg-primary text-white text-sm font-bold rounded-lg hover:bg-primary/90 transition-colors shadow-lg shadow-primary/20 flex items-center gap-2" onclick="document.getElementById('addDomainForm').classList.toggle('hidden')">
        <span class="material-symbols-outlined">add</span> Create Domain
    </button>
</div>

<div class="glass rounded-xl p-6 mb-8 border border-primary/30 shadow-[0_0_15px_rgba(7,182,213,0.15)]">
    <h3 class="text-lg font-semibold text-slate-100 mb-2">PHP Selector</h3>
    <p class="text-slate-400 text-sm mb-4">Switch PHP version for a domain without leaving this page.</p>
    <form id="phpVersionForm" class="grid grid-cols-1 md:grid-cols-3 gap-4 items-end">
        <div>
            <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Domain</label>
            <select id="phpDomain" class="w-full bg-slate-800/50 border border-slate-700 rounded-lg px-4 py-2.5 text-sm text-slate-200 focus:ring-1 focus:ring-primary focus:border-primary transition-all outline-none" required>
                <TMPL_VAR NAME=domain_options>
            </select>
        </div>
        <div>
            <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Target PHP Version</label>
            <select id="phpVersion" class="w-full bg-slate-800/50 border border-slate-700 rounded-lg px-4 py-2.5 text-sm text-slate-200 focus:ring-1 focus:ring-primary focus:border-primary transition-all outline-none" required>
                <option value="8.4">PHP 8.4</option>
                <option value="8.3">PHP 8.3</option>
                <option value="8.2" selected>PHP 8.2</option>
                <option value="8.1">PHP 8.1</option>
                <option value="8.0">PHP 8.0</option>
            </select>
        </div>
        <div>
            <button type="submit" class="w-full py-2.5 bg-primary text-white text-sm font-bold rounded-lg hover:bg-primary/90 transition-colors">Apply PHP Version</button>
        </div>
    </form>
    <p id="phpSelectorStatus" class="mt-3 text-xs text-slate-400"></p>
</div>

<div id="addDomainForm" class="hidden glass rounded-xl p-6 mb-8 border border-primary/30 shadow-[0_0_15px_rgba(7,182,213,0.15)] relative">
    <button class="absolute top-4 right-4 text-slate-400 hover:text-slate-200" onclick="document.getElementById('addDomainForm').classList.add('hidden')">
        <span class="material-symbols-outlined">close</span>
    </button>
    <h3 class="text-lg font-semibold text-slate-100 mb-4">Add New Domain</h3>
    <form method="POST" action="/api/web/create_vhost">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-4">
            <div>
                <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Domain Name</label>
                <input type="text" name="domain" class="w-full bg-slate-800/50 border border-slate-700 rounded-lg px-4 py-2.5 text-sm text-slate-200 placeholder:text-slate-500 focus:ring-1 focus:ring-primary focus:border-primary transition-all outline-none" placeholder="e.g. example.com" required>
            </div>
            <div>
                <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Document Root</label>
                <input type="text" name="docroot" class="w-full bg-slate-800/50 border border-slate-700 rounded-lg px-4 py-2.5 text-sm text-slate-200 placeholder:text-slate-500 focus:ring-1 focus:ring-primary focus:border-primary transition-all outline-none" placeholder="/home/user/public_html/example.com">
            </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-end">
            <div>
                <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">PHP Version</label>
                <select name="php" class="w-full bg-slate-800/50 border border-slate-700 rounded-lg px-4 py-2.5 text-sm text-slate-200 focus:ring-1 focus:ring-primary focus:border-primary transition-all outline-none">
                    <option value="8.3">PHP 8.3 (Latest)</option>
                    <option value="8.2" selected>PHP 8.2</option>
                    <option value="8.1">PHP 8.1</option>
                </select>
            </div>
            <div>
                <button type="submit" class="w-full py-2.5 bg-primary text-white text-sm font-bold rounded-lg hover:bg-primary/90 transition-colors">Create Domain</button>
            </div>
        </div>
    </form>
</div>

<script>
(() => {
    const form = document.getElementById('phpVersionForm');
    const status = document.getElementById('phpSelectorStatus');
    if (!form || !status) {
        return;
    }

    form.addEventListener('submit', async (event) => {
        event.preventDefault();

        const domain = document.getElementById('phpDomain').value;
        const version = document.getElementById('phpVersion').value;

        status.textContent = 'Applying PHP version...';
        status.className = 'mt-3 text-xs text-slate-400';

        try {
            const response = await fetch('/api/web/set_php_version', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ domain, version })
            });

            const payload = await response.json();
            if (!response.ok || !payload.success) {
                throw new Error(payload.error || payload.detail || 'Failed to apply PHP version');
            }

            status.textContent = payload.message || `PHP ${version} applied to ${domain}.`;
            status.className = 'mt-3 text-xs text-emerald-400';
            setTimeout(() => window.location.reload(), 900);
        } catch (err) {
            status.textContent = err.message || 'Unable to apply PHP version.';
            status.className = 'mt-3 text-xs text-red-400';
        }
    });
})();
</script>

<div class="glass rounded-xl overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead class="bg-slate-800/30 border-b border-border-dark">
                <tr>
                    <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">Domain</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">Document Root</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">PHP</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">SSL</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">Status</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-border-dark/50 text-sm">
                <TMPL_LOOP NAME=domains>
                <tr class="hover:bg-slate-800/20 transition-colors">
                    <td class="px-6 py-4 font-bold text-slate-200"><TMPL_VAR NAME=domain></td>
                    <td class="px-6 py-4 font-mono text-slate-400 text-xs"><TMPL_VAR NAME=docroot></td>
                    <td class="px-6 py-4"><span class="px-2 py-1 rounded bg-purple-500/10 text-purple-400 text-xs font-bold border border-purple-500/20"><TMPL_VAR NAME=php></span></td>
                    <td class="px-6 py-4">
                        <TMPL_IF NAME=ssl>
                            <span class="px-2 py-1 rounded bg-green-500/10 text-green-400 text-xs font-bold border border-green-500/20 flex items-center w-max gap-1">
                                <span class="material-symbols-outlined text-[14px]">lock</span> Active
                            </span>
                        <TMPL_ELSE>
                            <span class="px-2 py-1 rounded bg-slate-500/10 text-slate-400 text-xs font-bold border border-slate-500/20 flex items-center w-max gap-1">
                                <span class="material-symbols-outlined text-[14px]">lock_open</span> None
                            </span>
                        </TMPL_IF>
                    </td>
                    <td class="px-6 py-4"><span class="px-2 py-1 rounded bg-blue-500/10 text-blue-400 text-xs font-bold border border-blue-500/20"><TMPL_VAR NAME=status></span></td>
                    <td class="px-6 py-4 text-right space-x-2">
                        <a href="/dns?domain=<TMPL_VAR NAME=domain>" class="inline-flex items-center justify-center w-8 h-8 rounded bg-slate-800/50 hover:bg-slate-700 text-slate-300 transition-colors" title="DNS">
                            <span class="material-symbols-outlined text-[18px]">dns</span>
                        </a>
                        <a href="/filemanager?dir=<TMPL_VAR NAME=docroot>" class="inline-flex items-center justify-center w-8 h-8 rounded bg-slate-800/50 hover:bg-slate-700 text-slate-300 transition-colors" title="Files">
                            <span class="material-symbols-outlined text-[18px]">folder</span>
                        </a>
                        <form method="POST" action="/api/domain/delete" class="inline-block" onsubmit="return confirm('Delete domain <TMPL_VAR NAME=domain>?');">
                            <input type="hidden" name="domain" value="<TMPL_VAR NAME=domain>">
                            <button type="submit" class="inline-flex items-center justify-center w-8 h-8 rounded bg-red-500/10 hover:bg-red-500/20 text-red-500 transition-colors" title="Delete">
                                <span class="material-symbols-outlined text-[18px]">delete</span>
                            </button>
                        </form>
                    </td>
                </tr>
                </TMPL_LOOP>
            </tbody>
        </table>
    </div>
</div>
