<div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-6">
    <div>
        <h1 class="text-2xl font-extrabold text-slate-900 dark:text-white">Cron Jobs</h1>
        <p class="text-slate-500 dark:text-slate-400 mt-1">Schedule commands and scripts to run automatically</p>
    </div>
    <button class="px-4 py-2 bg-primary text-white text-sm font-bold rounded-lg hover:bg-primary/90 transition-colors shadow-lg shadow-primary/20 flex items-center gap-2" onclick="document.getElementById('addCronForm').classList.toggle('hidden')">
        <span class="material-symbols-outlined">add</span> Create Job
    </button>
</div>

<div id="addCronForm" class="hidden glass rounded-xl p-6 mb-8 border border-primary/30 shadow-[0_0_15px_rgba(7,182,213,0.15)] relative">
    <button class="absolute top-4 right-4 text-slate-400 hover:text-slate-200" onclick="document.getElementById('addCronForm').classList.add('hidden')">
        <span class="material-symbols-outlined">close</span>
    </button>
    <h3 class="text-lg font-semibold text-slate-100 mb-4">Add Cron Job</h3>
    <form method="POST" action="/api/cron/add">
        <div class="grid grid-cols-1 md:grid-cols-5 gap-4 mb-4">
            <div>
                <label class="block text-xs font-semibold text-slate-400 mb-2">Minute</label>
                <input type="text" name="min" class="w-full bg-slate-800/50 border border-slate-700 rounded-lg px-3 py-2.5 text-sm font-mono text-slate-200 placeholder:text-slate-600 focus:ring-1 focus:ring-primary focus:border-primary transition-all outline-none" value="*" required>
            </div>
            <div>
                <label class="block text-xs font-semibold text-slate-400 mb-2">Hour</label>
                <input type="text" name="hour" class="w-full bg-slate-800/50 border border-slate-700 rounded-lg px-3 py-2.5 text-sm font-mono text-slate-200 placeholder:text-slate-600 focus:ring-1 focus:ring-primary focus:border-primary transition-all outline-none" value="*" required>
            </div>
            <div>
                <label class="block text-xs font-semibold text-slate-400 mb-2">Day</label>
                <input type="text" name="day" class="w-full bg-slate-800/50 border border-slate-700 rounded-lg px-3 py-2.5 text-sm font-mono text-slate-200 placeholder:text-slate-600 focus:ring-1 focus:ring-primary focus:border-primary transition-all outline-none" value="*" required>
            </div>
            <div>
                <label class="block text-xs font-semibold text-slate-400 mb-2">Month</label>
                <input type="text" name="mon" class="w-full bg-slate-800/50 border border-slate-700 rounded-lg px-3 py-2.5 text-sm font-mono text-slate-200 placeholder:text-slate-600 focus:ring-1 focus:ring-primary focus:border-primary transition-all outline-none" value="*" required>
            </div>
            <div>
                <label class="block text-xs font-semibold text-slate-400 mb-2">Weekday</label>
                <input type="text" name="wday" class="w-full bg-slate-800/50 border border-slate-700 rounded-lg px-3 py-2.5 text-sm font-mono text-slate-200 placeholder:text-slate-600 focus:ring-1 focus:ring-primary focus:border-primary transition-all outline-none" value="*" required>
            </div>
        </div>
        <div class="mb-4">
            <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Command</label>
            <input type="text" name="command" class="w-full bg-slate-800/50 border border-slate-700 rounded-lg px-4 py-2.5 text-sm font-mono text-slate-200 placeholder:text-slate-600 focus:ring-1 focus:ring-primary focus:border-primary transition-all outline-none" placeholder="/usr/bin/php /home/user/public_html/cron.php" required>
        </div>
        <button type="submit" class="py-2.5 px-6 bg-primary text-white text-sm font-bold rounded-lg hover:bg-primary/90 transition-colors">Add Job</button>
    </form>
</div>

<div class="glass rounded-xl overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead class="bg-slate-800/30 border-b border-border-dark">
                <tr>
                    <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">Schedule</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">Command</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-border-dark/50 text-sm">
                <TMPL_LOOP NAME=cron_jobs>
                <tr class="hover:bg-slate-800/20 transition-colors">
                    <td class="px-6 py-4 font-mono font-bold text-primary"><TMPL_VAR NAME=schedule></td>
                    <td class="px-6 py-4 font-mono text-slate-300 break-all"><TMPL_VAR NAME=command></td>
                    <td class="px-6 py-4 text-right space-x-2">
                        <button class="inline-flex items-center justify-center w-8 h-8 rounded bg-slate-800/50 hover:bg-slate-700 text-slate-300 transition-colors" title="Edit">
                            <span class="material-symbols-outlined text-[18px]">edit</span>
                        </button>
                        <button class="inline-flex items-center justify-center w-8 h-8 rounded bg-red-500/10 hover:bg-red-500/20 text-red-500 transition-colors" title="Delete">
                            <span class="material-symbols-outlined text-[18px]">delete</span>
                        </button>
                    </td>
                </tr>
                </TMPL_LOOP>
                <TMPL_UNLESS NAME=cron_jobs>
                <tr><td colspan="3" class="px-6 py-10 text-center text-slate-500">No cron jobs configured</td></tr>
                </TMPL_UNLESS>
            </tbody>
        </table>
    </div>
</div>
