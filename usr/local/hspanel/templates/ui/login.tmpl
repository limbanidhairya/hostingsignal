<!DOCTYPE html>
<html class="dark" lang="en">
<head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>HS-Panel | Security Gate</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;family=Outfit:wght@300;400;500;600;700&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#00d9ff",
                        "background-light": "#f5f8f8",
                        "background-dark": "#0f2023",
                        "navy-deep": "#070d0e",
                    },
                    fontFamily: { "display": ["Outfit", "Inter", "sans-serif"] },
                    borderRadius: {"DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px"},
                },
            },
        }
    </script>
<style>
        .glass-card {
            background: rgba(23, 49, 54, 0.6);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(0, 217, 255, 0.2);
            box-shadow: 0 0 20px rgba(0, 217, 255, 0.1);
        }
        .neon-glow { text-shadow: 0 0 10px rgba(0, 217, 255, 0.5); }
        .bg-mesh {
            background-image: 
                radial-gradient(at 0% 0%, rgba(0, 217, 255, 0.15) 0px, transparent 50%),
                radial-gradient(at 100% 0%, rgba(0, 217, 255, 0.1) 0px, transparent 50%),
                radial-gradient(at 50% 100%, rgba(7, 13, 14, 1) 0px, transparent 80%);
        }
    </style>
</head>
<body class="bg-background-light dark:bg-background-dark font-display text-slate-900 dark:text-slate-100 min-h-screen flex flex-col">
<div class="relative flex min-h-screen w-full flex-col bg-navy-deep overflow-hidden">
<div class="absolute inset-0 z-0 bg-mesh opacity-60"></div>
<div class="layout-container flex h-full grow flex-col z-10">
<header class="flex items-center justify-between whitespace-nowrap border-b border-solid border-primary/10 px-6 md:px-10 py-4">
<div class="flex items-center gap-3">
<div class="flex items-center justify-center size-10 rounded-lg bg-primary/10 border border-primary/30">
<span class="material-symbols-outlined text-primary neon-glow">shield_lock</span>
</div>
<h2 class="text-slate-100 text-xl font-bold tracking-tight">HS-Panel</h2>
</div>
<div class="flex items-center gap-6">
<a href="#" class="text-slate-400 hover:text-primary transition-colors text-sm font-medium hidden md:block">Partner Portal</a>
</div>
</header>
<main class="flex-1 flex items-center justify-center p-6">
<div class="w-full max-w-[460px]">
<div class="glass-card rounded-xl overflow-hidden p-8 md:p-12 relative border-t-2 border-t-primary/40">
<div class="flex flex-col items-center mb-10">
<div class="size-16 mb-4 flex items-center justify-center rounded-2xl bg-primary/5 border border-primary/20 shadow-[0_0_15px_rgba(0,217,255,0.2)]">
<span class="material-symbols-outlined text-primary text-4xl neon-glow">rocket_launch</span>
</div>
<h1 class="text-2xl md:text-3xl font-bold text-white tracking-tight">Security Gate</h1>
<p class="text-slate-400 mt-2 text-sm">Enterprise Web Hosting Access</p>
</div>

<TMPL_IF NAME=error>
<div class="mb-6 p-4 rounded-lg bg-red-500/10 border border-red-500/20 text-red-500 text-sm font-medium flex items-center gap-3">
    <span class="material-symbols-outlined text-lg">error</span>
    Invalid credentials. Access denied.
</div>
</TMPL_IF>

<form class="space-y-6" method="POST" action="/login">
<div class="space-y-1.5">
<label class="text-slate-300 text-xs font-semibold uppercase tracking-widest ml-1">Username / Email</label>
<div class="relative">
<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-500 text-xl">alternate_email</span>
<input name="user" class="w-full pl-12 pr-4 py-4 bg-navy-deep/40 border border-slate-700/50 rounded-lg focus:ring-1 focus:ring-primary focus:border-primary outline-none text-slate-100 transition-all placeholder:text-slate-600" placeholder="root or username" type="text" required autofocus/>
</div>
</div>
<div class="space-y-1.5">
<div class="flex justify-between items-end">
<label class="text-slate-300 text-xs font-semibold uppercase tracking-widest ml-1">Password</label>
<a class="text-xs text-primary/70 hover:text-primary transition-colors mb-1" href="#">Forgot?</a>
</div>
<div class="relative">
<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-500 text-xl">lock</span>
<input name="pass" class="w-full pl-12 pr-12 py-4 bg-navy-deep/40 border border-slate-700/50 rounded-lg focus:ring-1 focus:ring-primary focus:border-primary outline-none text-slate-100 transition-all placeholder:text-slate-600" placeholder="••••••••" type="password" required/>
</div>
</div>
<div class="pt-4">
<button class="w-full bg-gradient-to-r from-primary to-[#00a3cc] hover:from-[#00efff] hover:to-primary text-navy-deep font-bold py-4 rounded-lg shadow-[0_0_20px_rgba(0,217,255,0.3)] transition-all transform hover:scale-[1.01] active:scale-[0.99] flex items-center justify-center gap-2" type="submit">
<span>Access Security Gate</span>
<span class="material-symbols-outlined text-xl">arrow_forward</span>
</button>
</div>
</form>
</div>
<div class="mt-8 text-center text-slate-600 text-[10px] uppercase tracking-[0.2em]">
    Protected by Advanced Shielding © 2024 HS-Panel Systems
</div>
</div>
</main>
</div>
<div class="absolute -bottom-24 -left-24 size-96 bg-primary/5 blur-[120px] rounded-full z-0"></div>
<div class="absolute -top-24 -right-24 size-96 bg-primary/5 blur-[120px] rounded-full z-0"></div>
</div>
</body>
</html>
