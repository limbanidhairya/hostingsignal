<div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-6">
    <div>
        <h1 class="text-2xl font-extrabold text-slate-900 dark:text-white">DNS Zone Editor</h1>
        <p class="text-slate-500 dark:text-slate-400 mt-1">Manage DNS records for your domains</p>
    </div>
    
    <div class="flex items-center gap-4">
        <form method="GET" action="/dns" class="flex items-center gap-3">
            <label class="text-sm font-semibold text-slate-400 uppercase tracking-widest">Select Domain:</label>
            <select name="domain" class="bg-slate-800/50 border border-slate-700 rounded-lg px-4 py-2 text-sm text-slate-200 focus:ring-1 focus:ring-primary focus:border-primary transition-all outline-none w-64" onchange="this.form.submit()">
                <TMPL_LOOP NAME=domain_options>
                    <option value="<TMPL_VAR NAME=domain>" <TMPL_IF NAME=selected>selected</TMPL_IF>><TMPL_VAR NAME=domain></option>
                </TMPL_LOOP>
            </select>
        </form>
    </div>
</div>

<div class="glass rounded-xl mb-8 border border-primary/30 shadow-[0_0_15px_rgba(7,182,213,0.15)] relative overflow-hidden">
    <div class="px-6 py-4 flex items-center border-b border-border-dark bg-slate-800/30">
        <h3 class="font-bold text-slate-100 flex items-center gap-2">
            <span class="material-symbols-outlined text-primary">add_circle</span> Add Record to <TMPL_VAR NAME=current_domain>
        </h3>
    </div>
    <div class="p-6">
        <form method="POST" action="/api/dns/add_record">
            <input type="hidden" name="domain" value="<TMPL_VAR NAME=current_domain>">
            <div class="grid grid-cols-1 md:grid-cols-12 gap-4 items-end">
                <div class="md:col-span-3">
                    <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Name</label>
                    <div class="flex items-center">
                        <input type="text" name="name" class="w-full bg-slate-800/50 border border-slate-700 border-r-0 rounded-l-lg px-3 py-2.5 text-sm text-slate-200 placeholder:text-slate-600 focus:ring-1 focus:ring-primary focus:border-primary transition-all outline-none" placeholder="subdomain">
                        <span class="bg-slate-800/80 border border-slate-700 rounded-r-lg px-3 py-2.5 text-sm text-slate-400 font-mono whitespace-nowrap">.<TMPL_VAR NAME=current_domain></span>
                    </div>
                </div>
                <div class="md:col-span-2">
                    <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Type</label>
                    <select name="type" class="w-full bg-slate-800/50 border border-slate-700 rounded-lg px-3 py-2.5 text-sm text-slate-200 focus:ring-1 focus:ring-primary focus:border-primary transition-all outline-none">
                        <option value="A">A</option>
                        <option value="AAAA">AAAA</option>
                        <option value="CNAME">CNAME</option>
                        <option value="MX">MX</option>
                        <option value="TXT">TXT</option>
                        <option value="SRV">SRV</option>
                    </select>
                </div>
                <div class="md:col-span-4">
                    <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Value</label>
                    <input type="text" name="value" class="w-full bg-slate-800/50 border border-slate-700 rounded-lg px-3 py-2.5 text-sm text-slate-200 placeholder:text-slate-600 focus:ring-1 focus:ring-primary focus:border-primary transition-all outline-none" placeholder="192.0.2.1" required>
                </div>
                <div class="md:col-span-2">
                    <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">TTL</label>
                    <input type="number" name="ttl" class="w-full bg-slate-800/50 border border-slate-700 rounded-lg px-3 py-2.5 text-sm text-slate-200 focus:ring-1 focus:ring-primary focus:border-primary transition-all outline-none" value="14400">
                </div>
                <div class="md:col-span-1">
                    <button type="submit" class="w-full py-2.5 bg-primary text-white text-sm font-bold rounded-lg hover:bg-primary/90 transition-colors">Add</button>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="glass rounded-xl overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead class="bg-slate-800/30 border-b border-border-dark">
                <tr>
                    <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">Name</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">TTL</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">Type</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">Value</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-border-dark/50 text-sm">
                <TMPL_LOOP NAME=records>
                <tr class="hover:bg-slate-800/20 transition-colors">
                    <td class="px-6 py-4 font-mono font-bold text-slate-200"><TMPL_VAR NAME=name></td>
                    <td class="px-6 py-4 font-mono text-slate-400 text-xs"><TMPL_VAR NAME=ttl></td>
                    <td class="px-6 py-4"><span class="px-2 py-1 rounded bg-purple-500/10 text-purple-400 text-xs font-bold border border-purple-500/20"><TMPL_VAR NAME=type></span></td>
                    <td class="px-6 py-4 font-mono text-slate-300 break-all max-w-[400px]"><TMPL_VAR NAME=value></td>
                    <td class="px-6 py-4 text-right space-x-2">
                        <button class="inline-flex items-center justify-center w-8 h-8 rounded bg-slate-800/50 hover:bg-slate-700 text-slate-300 transition-colors" title="Edit">
                            <span class="material-symbols-outlined text-[18px]">edit</span>
                        </button>
                        <button class="inline-flex items-center justify-center w-8 h-8 rounded bg-red-500/10 hover:bg-red-500/20 text-red-500 transition-colors" title="Delete">
                            <span class="material-symbols-outlined text-[18px]">delete</span>
                        </button>
                    </td>
                </tr>
                </TMPL_LOOP>
            </tbody>
        </table>
    </div>
</div>
