<div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-6">
    <div>
        <h1 class="text-2xl font-extrabold text-slate-900 dark:text-white">SSL Certificates</h1>
        <p class="text-slate-500 dark:text-slate-400 mt-1">Manage free Let's Encrypt and custom SSL certificates</p>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
    <div class="glass rounded-xl overflow-hidden flex flex-col">
        <div class="px-6 py-4 border-b border-border-dark">
            <h3 class="font-bold text-slate-100 flex items-center gap-2"><span class="material-symbols-outlined text-green-500">verified_user</span> Auto-Issue Let's Encrypt</h3>
        </div>
        <div class="p-6 flex-1 flex flex-col justify-center">
            <p class="text-slate-400 text-sm mb-6 leading-relaxed">
                Automatically request and install a free SSL certificate for your domain. DNS must resolve to this server.
            </p>
            <form method="POST" action="/api/ssl/request_cert">
                <div class="mb-5">
                    <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Select Domain</label>
                    <select name="domain" class="w-full bg-slate-800/50 border border-slate-700 rounded-lg px-4 py-3 text-sm text-slate-200 focus:ring-1 focus:ring-primary focus:border-primary transition-all outline-none">
                        <TMPL_LOOP NAME=domain_options>
                            <option value="<TMPL_VAR NAME=domain>"><TMPL_VAR NAME=domain></option>
                        </TMPL_LOOP>
                    </select>
                </div>
                <div class="mb-6">
                    <label class="flex items-center gap-3 text-sm text-slate-300 cursor-pointer">
                        <input type="checkbox" name="include_www" class="w-5 h-5 rounded border-slate-600 bg-slate-800 text-primary" checked>
                        <span>Include www alias</span>
                    </label>
                </div>
                <button type="submit" class="w-full py-3 bg-primary text-white font-bold rounded-lg hover:bg-primary/90 transition-colors shadow-lg shadow-primary/20">Request Free Certificate</button>
            </form>
        </div>
    </div>

    <div class="glass rounded-xl overflow-hidden">
        <div class="px-6 py-4 border-b border-border-dark flex justify-between items-center">
            <h3 class="font-bold text-slate-100 flex items-center gap-2"><span class="material-symbols-outlined text-purple-500">vpn_key</span> Custom Certificate</h3>
            <button class="text-xs bg-slate-800 text-slate-300 border border-slate-700 px-3 py-1.5 rounded-lg hover:bg-slate-700 transition-colors" onclick="document.getElementById('customSSLForm').classList.toggle('hidden');">Toggle Form</button>
        </div>
        <div class="p-6">
            <div id="customSSLForm" class="hidden">
                <form method="POST" action="/api/ssl/install_cert">
                    <div class="mb-4">
                        <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Domain</label>
                        <input type="text" name="domain" class="w-full bg-slate-800/50 border border-slate-700 rounded-lg px-4 py-2.5 text-sm text-slate-200 focus:ring-1 focus:ring-primary focus:border-primary transition-all outline-none" placeholder="example.com" required>
                    </div>
                    <div class="mb-4">
                        <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Private Key (KEY)</label>
                        <textarea name="key" class="w-full bg-slate-800/50 border border-slate-700 rounded-lg px-4 py-3 text-xs font-mono text-slate-300 focus:ring-1 focus:ring-primary focus:border-primary transition-all outline-none" rows="4" placeholder="-----BEGIN PRIVATE KEY-----..."></textarea>
                    </div>
                    <div class="mb-5">
                        <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Certificate (CRT)</label>
                        <textarea name="cert" class="w-full bg-slate-800/50 border border-slate-700 rounded-lg px-4 py-3 text-xs font-mono text-slate-300 focus:ring-1 focus:ring-primary focus:border-primary transition-all outline-none" rows="4" placeholder="-----BEGIN CERTIFICATE-----..."></textarea>
                    </div>
                    <button type="submit" class="w-full py-2.5 bg-slate-700 text-white font-bold rounded-lg hover:bg-slate-600 transition-colors">Install Certificate</button>
                </form>
            </div>
            <div class="h-full flex flex-col items-center justify-center text-center py-8" style="display: var(--fallback-display, block);" id="customPlaceholder">
                <span class="material-symbols-outlined text-5xl text-slate-600 mb-4 block">upload_file</span>
                <p class="text-slate-400 text-sm">Have your own commercial certificate?<br>Toggle the form above to paste your KEY and CRT files manually.</p>
            </div>
            <script>
                // simple inline script to toggle placeholder
                document.getElementById('customSSLForm').addEventListener('transitionend', function() {
                    // This logic handles hiding the placeholder when form is shown
                });
                const btn = document.querySelector('[onclick*="customSSLForm"]');
                btn.addEventListener('click', () => {
                    const form = document.getElementById('customSSLForm');
                    const ph = document.getElementById('customPlaceholder');
                    if (form.classList.contains('hidden')) {
                        ph.style.display = 'block';
                    } else {
                        ph.style.display = 'none';
                    }
                });
            </script>
        </div>
    </div>
</div>

<div class="glass rounded-xl overflow-hidden">
    <div class="px-6 py-4 border-b border-border-dark">
        <h3 class="font-bold text-slate-100 flex items-center gap-2"><span class="material-symbols-outlined text-slate-400">admin_panel_settings</span> Installed Certificates</h3>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead class="bg-slate-800/30 border-b border-border-dark">
                <tr>
                    <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">Domain</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">Issuer</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">Status</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">Expires</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">Auto-Renew</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-border-dark/50 text-sm">
                <TMPL_LOOP NAME=certificates>
                <tr class="hover:bg-slate-800/20 transition-colors">
                    <td class="px-6 py-4 font-bold text-slate-200 flex items-center gap-2">
                        <span class="material-symbols-outlined text-[18px] text-green-500">lock</span> <TMPL_VAR NAME=domain>
                    </td>
                    <td class="px-6 py-4"><span class="px-2 py-1 rounded bg-purple-500/10 text-purple-400 text-xs font-bold border border-purple-500/20"><TMPL_VAR NAME=issuer></span></td>
                    <td class="px-6 py-4"><span class="px-2 py-1 rounded bg-green-500/10 text-green-400 text-xs font-bold border border-green-500/20"><TMPL_VAR NAME=status></span></td>
                    <td class="px-6 py-4 text-slate-400"><TMPL_VAR NAME=expires></td>
                    <td class="px-6 py-4">
                        <TMPL_IF NAME=autorenew>
                            <span class="text-green-500 flex items-center gap-1 font-medium text-xs"><span class="material-symbols-outlined text-[16px]">check_circle</span> Enabled</span>
                        <TMPL_ELSE>
                            <span class="text-slate-500 flex items-center gap-1 font-medium text-xs"><span class="material-symbols-outlined text-[16px]">cancel</span> Disabled</span>
                        </TMPL_IF>
                    </td>
                    <td class="px-6 py-4 text-right space-x-2">
                        <button class="inline-flex items-center justify-center w-8 h-8 rounded bg-slate-800/50 hover:bg-slate-700 text-slate-300 transition-colors" title="Force Renew">
                            <span class="material-symbols-outlined text-[18px]">autorenew</span>
                        </button>
                        <button class="inline-flex items-center justify-center w-8 h-8 rounded bg-red-500/10 hover:bg-red-500/20 text-red-500 transition-colors" title="Delete">
                            <span class="material-symbols-outlined text-[18px]">delete</span>
                        </button>
                    </td>
                </tr>
                </TMPL_LOOP>
                <TMPL_UNLESS NAME=certificates>
                <tr><td colspan="6" class="px-6 py-10 text-center text-slate-500">No certificates installed</td></tr>
                </TMPL_UNLESS>
            </tbody>
        </table>
    </div>
</div>
