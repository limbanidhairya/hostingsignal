<!DOCTYPE html>
<html class="dark" lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>HS-Panel — <TMPL_VAR NAME=title></title>
    
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#07b6d5",
                        "accent": "#00d4ff",
                        "background-light": "#f5f8f8",
                        "background-dark": "#0f172a",
                        "card-dark": "#1e293b",
                        "border-dark": "#334155"
                    },
                    fontFamily: {
                        "display": ["Inter", "sans-serif"]
                    },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                },
            },
        }
    </script>
    
    <style>
        body { font-family: 'Inter', sans-serif; }
        .sidebar-item { transition: all 0.2s; }
        .sidebar-item:hover { background-color: rgba(255, 255, 255, 0.05); }
        .sidebar-item-active {
            background-color: rgba(7, 182, 213, 0.15);
            color: #07b6d5 !important;
            border-left: 3px solid #07b6d5;
        }
        .custom-scrollbar::-webkit-scrollbar { width: 4px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #1e293b; border-radius: 10px; }
        .glass { background: rgba(30, 41, 59, 0.7); backdrop-filter: blur(8px); border: 1px solid rgba(51, 65, 85, 0.5); }
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
    </style>
</head>
<body class="bg-background-light dark:bg-background-dark text-slate-900 dark:text-slate-100 min-h-screen flex flex-col font-display">

<header class="h-16 border-b border-slate-200 dark:border-slate-800 flex items-center justify-between px-6 bg-white/50 dark:bg-background-dark/80 backdrop-blur-md sticky top-0 z-50">
    <div class="flex items-center gap-8">
        <div class="flex items-center gap-2">
            <div class="w-8 h-8 bg-primary rounded-lg flex items-center justify-center text-white">
                <span class="material-symbols-outlined text-xl">rocket_launch</span>
            </div>
            <h1 class="text-xl font-bold tracking-tight text-slate-900 dark:text-white">HS-Panel</h1>
        </div>
        <div class="hidden md:flex items-center gap-2">
            <div class="relative">
                <select class="appearance-none bg-slate-100 dark:bg-slate-800 border-none rounded-lg py-2 pl-4 pr-10 text-sm font-medium focus:ring-2 focus:ring-primary/50 text-slate-700 dark:text-slate-200 cursor-pointer">
                    <option><TMPL_VAR NAME=domain></option>
                </select>
                <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none text-lg">expand_more</span>
            </div>
        </div>
    </div>
    
    <div class="flex items-center gap-4">
        <div class="hidden sm:flex items-center bg-slate-100 dark:bg-slate-800 rounded-lg px-3 py-1.5 gap-2 border border-slate-200 dark:border-slate-700">
            <span class="material-symbols-outlined text-primary text-lg">search</span>
            <input class="bg-transparent border-none focus:ring-0 p-0 text-sm placeholder:text-slate-500 w-48 text-slate-200 outline-none" placeholder="Search features..." type="text"/>
        </div>
        <button class="relative p-2 text-slate-500 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg transition-colors">
            <span class="material-symbols-outlined">notifications</span>
            <span class="absolute top-2 right-2 w-2 h-2 bg-red-500 rounded-full border-2 border-white dark:border-background-dark"></span>
        </button>
        <div class="h-8 w-[1px] bg-slate-200 dark:border-slate-800 mx-1"></div>
        <div class="flex items-center gap-3 pl-2 cursor-pointer hover:opacity-80">
            <div class="text-right hidden sm:block">
                <p class="text-xs font-bold text-slate-900 dark:text-white leading-none"><TMPL_VAR NAME=user></p>
                <p class="text-[10px] text-slate-500 font-medium mt-1">PRO PLAN</p>
            </div>
            <div class="w-9 h-9 rounded-full bg-slate-200 dark:bg-slate-700 border-2 border-primary/20 overflow-hidden flex items-center justify-center font-bold text-slate-400">
                <TMPL_VAR NAME=user_initial>
            </div>
        </div>
        <a href="/logout" class="p-2 text-slate-500 hover:text-red-500 rounded-lg transition-colors" title="Logout">
            <span class="material-symbols-outlined">logout</span>
        </a>
    </div>
</header>

<div class="flex flex-1 overflow-hidden">
    <aside class="w-64 border-r border-slate-200 dark:border-slate-800 bg-white dark:bg-background-dark hidden lg:flex flex-col py-6 custom-scrollbar overflow-y-auto">
        <nav class="flex flex-col px-3 space-y-1">
            <p class="px-4 text-[11px] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest mb-2">Management</p>
            
            <a class="sidebar-item <TMPL_IF NAME=is_dashboard>sidebar-item-active</TMPL_IF> flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white" href="/dashboard">
                <span class="material-symbols-outlined text-[22px]">grid_view</span>
                Dashboard
            </a>
            
            <a class="sidebar-item <TMPL_IF NAME=is_domains>sidebar-item-active</TMPL_IF> flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white" href="/domains">
                <span class="material-symbols-outlined text-[22px]">language</span>
                Domains
            </a>
            
            <a class="sidebar-item <TMPL_IF NAME=is_email>sidebar-item-active</TMPL_IF> flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white" href="/email">
                <span class="material-symbols-outlined text-[22px]">mail</span>
                Email Accounts
            </a>
            
            <a class="sidebar-item <TMPL_IF NAME=is_databases>sidebar-item-active</TMPL_IF> flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white" href="/databases">
                <span class="material-symbols-outlined text-[22px]">database</span>
                Databases
            </a>
            
            <a class="sidebar-item <TMPL_IF NAME=is_filemanager>sidebar-item-active</TMPL_IF> flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white" href="/filemanager">
                <span class="material-symbols-outlined text-[22px]">folder_open</span>
                File Manager
            </a>
            
            <a class="sidebar-item <TMPL_IF NAME=is_dns>sidebar-item-active</TMPL_IF> flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white" href="/dns">
                <span class="material-symbols-outlined text-[22px]">dns</span>
                DNS Management
            </a>
            
            <p class="px-4 text-[11px] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest mt-6 mb-2">Security & Advanced</p>
            
            <a class="sidebar-item <TMPL_IF NAME=is_backups>sidebar-item-active</TMPL_IF> flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white" href="/backups">
                <span class="material-symbols-outlined text-[22px]">history</span>
                Backups
            </a>

            <a class="sidebar-item <TMPL_IF NAME=is_ssl>sidebar-item-active</TMPL_IF> flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white" href="/ssl">
                <span class="material-symbols-outlined text-[22px]">verified_user</span>
                SSL Manager
            </a>
            
            <a class="sidebar-item <TMPL_IF NAME=is_cron>sidebar-item-active</TMPL_IF> flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white" href="/cron">
                <span class="material-symbols-outlined text-[22px]">schedule</span>
                Cron Jobs
            </a>
            
            <a class="sidebar-item <TMPL_IF NAME=is_metrics>sidebar-item-active</TMPL_IF> flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white" href="/metrics">
                <span class="material-symbols-outlined text-[22px]">query_stats</span>
                Metrics
            </a>
            
            <a class="sidebar-item <TMPL_IF NAME=is_settings>sidebar-item-active</TMPL_IF> flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white" href="/settings">
                <span class="material-symbols-outlined text-[22px]">settings</span>
                Settings
            </a>
        </nav>
        
        <div class="mt-auto px-6 py-4">
            <div class="bg-primary/10 rounded-xl p-4 border border-primary/20">
                <p class="text-xs font-bold text-primary uppercase mb-2">Support</p>
                <p class="text-xs text-slate-400 leading-relaxed mb-3">Need help with your hosting setup?</p>
                <button class="w-full py-2 bg-primary text-white text-xs font-bold rounded-lg hover:bg-primary/90 transition-colors">Open Ticket</button>
            </div>
        </div>
    </aside>
    
    <main class="flex-1 overflow-y-auto bg-background-light dark:bg-background-dark p-6 md:p-10 custom-scrollbar">
        <div class="max-w-7xl mx-auto space-y-8">
            <TMPL_VAR NAME=content>
            
            <footer class="pt-8 pb-4 border-t border-slate-200 dark:border-slate-800 flex flex-col sm:flex-row justify-between items-center gap-4 mt-12">
                <p class="text-xs text-slate-500 font-medium">© 2026 HS-Panel. All systems operational.</p>
                <div class="flex gap-6">
                    <a class="text-xs text-slate-500 hover:text-primary transition-colors font-bold uppercase tracking-tight" href="#">System Status</a>
                    <a class="text-xs text-slate-500 hover:text-primary transition-colors font-bold uppercase tracking-tight" href="#">API Docs</a>
                    <a class="text-xs text-slate-500 hover:text-primary transition-colors font-bold uppercase tracking-tight" href="#">Help Center</a>
                </div>
            </footer>
        </div>
    </main>
</div>

</body>
</html>
