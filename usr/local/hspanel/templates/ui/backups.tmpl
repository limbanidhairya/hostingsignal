<div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-6">
    <div>
        <h1 class="text-2xl font-extrabold text-slate-900 dark:text-white">Backups</h1>
        <p class="text-slate-500 dark:text-slate-400 mt-1">Manage and schedule automated server backups</p>
    </div>
    <div class="flex gap-3">
        <button class="px-4 py-2 bg-slate-800 text-white text-sm font-bold rounded-lg border border-slate-700 hover:bg-slate-700 transition-colors flex items-center gap-2" onclick="document.getElementById('scheduleForm').classList.toggle('hidden')">
            <span class="material-symbols-outlined text-[20px]">calendar_month</span> Schedule
        </button>
        <form method="POST" action="/api/backup/create">
            <button type="submit" class="px-4 py-2 bg-primary text-white text-sm font-bold rounded-lg hover:bg-primary/90 transition-colors shadow-lg shadow-primary/20 flex items-center gap-2">
                <span class="material-symbols-outlined text-[20px]">add_task</span> Generate Backup
            </button>
        </form>
    </div>
</div>

<div id="scheduleForm" class="hidden glass rounded-xl p-6 mb-8 border border-primary/30 shadow-[0_0_15px_rgba(7,182,213,0.15)] relative">
    <button class="absolute top-4 right-4 text-slate-400 hover:text-slate-200" onclick="document.getElementById('scheduleForm').classList.add('hidden')">
        <span class="material-symbols-outlined">close</span>
    </button>
    <h3 class="text-lg font-semibold text-slate-100 mb-4">Configure Backup Schedule</h3>
    <form method="POST" action="/api/backup/schedule">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-end">
            <div>
                <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Frequency</label>
                <select name="frequency" class="w-full bg-slate-800/50 border border-slate-700 rounded-lg px-4 py-2.5 text-sm text-slate-200 focus:ring-1 focus:ring-primary focus:border-primary transition-all outline-none">
                    <option value="daily" <TMPL_IF NAME=schedule_daily>selected</TMPL_IF>>Daily</option>
                    <option value="weekly" <TMPL_IF NAME=schedule_weekly>selected</TMPL_IF>>Weekly</option>
                    <option value="monthly" <TMPL_IF NAME=schedule_monthly>selected</TMPL_IF>>Monthly</option>
                </select>
            </div>
            <div>
                <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Retention (Days)</label>
                <input type="number" name="retention" class="w-full bg-slate-800/50 border border-slate-700 rounded-lg px-4 py-2.5 text-sm text-slate-200 focus:ring-1 focus:ring-primary focus:border-primary transition-all outline-none" value="<TMPL_VAR NAME=retention>" placeholder="7">
            </div>
            <div>
                <button type="submit" class="w-full py-2.5 bg-primary text-white text-sm font-bold rounded-lg hover:bg-primary/90 transition-colors">Save Schedule</button>
            </div>
        </div>
    </form>
</div>

<div class="glass rounded-xl overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead class="bg-slate-800/30 border-b border-border-dark">
                <tr>
                    <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">Date / Time</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">Type</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">Size</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">Status</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-border-dark/50 text-sm">
                <TMPL_LOOP NAME=backups>
                <tr class="hover:bg-slate-800/20 transition-colors">
                    <td class="px-6 py-4 font-mono font-bold text-slate-200"><TMPL_VAR NAME=date></td>
                    <td class="px-6 py-4"><span class="px-2 py-1 rounded bg-blue-500/10 text-blue-400 text-xs font-bold border border-blue-500/20"><TMPL_VAR NAME=type></span></td>
                    <td class="px-6 py-4 text-slate-400"><TMPL_VAR NAME=size></td>
                    <td class="px-6 py-4"><span class="px-2 py-1 rounded bg-green-500/10 text-green-400 text-xs font-bold border border-green-500/20"><TMPL_VAR NAME=status></span></td>
                    <td class="px-6 py-4 text-right space-x-2">
                        <button class="inline-flex items-center justify-center w-8 h-8 rounded bg-slate-800/50 hover:bg-primary/20 hover:text-primary text-slate-300 transition-colors" title="Download">
                            <span class="material-symbols-outlined text-[18px]">download</span>
                        </button>
                        <button class="inline-flex items-center justify-center w-8 h-8 rounded bg-slate-800/50 hover:bg-amber-500/20 hover:text-amber-500 text-slate-300 transition-colors" title="Restore">
                            <span class="material-symbols-outlined text-[18px]">restore</span>
                        </button>
                        <button class="inline-flex items-center justify-center w-8 h-8 rounded bg-red-500/10 hover:bg-red-500/20 text-red-500 transition-colors" title="Delete">
                            <span class="material-symbols-outlined text-[18px]">delete</span>
                        </button>
                    </td>
                </tr>
                </TMPL_LOOP>
                <TMPL_UNLESS NAME=backups>
                <tr><td colspan="5" class="px-6 py-10 text-center text-slate-500">No backups found</td></tr>
                </TMPL_UNLESS>
            </tbody>
        </table>
    </div>
</div>
