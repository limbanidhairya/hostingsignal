{
    "name": "backup_s3",
    "version": "1.0.0",
    "description": "Automated website backups to Amazon S3 or any S3-compatible storage (MinIO, DigitalOcean Spaces, etc.)",
    "author": "HostingSignal",
    "category": "backup",
    "min_panel_version": "1.0.0",
    "entry_point": "main.py",
    "hooks": [
        "backup.completed",
        "cron.daily"
    ],
    "ui_extensions": [
        {
            "type": "settings_panel",
            "label": "S3 Backup Settings",
            "route": "/plugins/backup-s3/settings"
        }
    ],
    "api_routes": [
        {
            "method": "POST",
            "path": "/api/plugins/backup-s3/configure",
            "handler": "configure"
        },
        {
            "method": "POST",
            "path": "/api/plugins/backup-s3/upload",
            "handler": "upload_backup"
        },
        {
            "method": "GET",
            "path": "/api/plugins/backup-s3/list",
            "handler": "list_backups"
        }
    ],
    "permissions": [
        "file_read",
        "network"
    ],
    "dependencies": [
        "boto3"
    ]
}