# HostingSignal Backend Environment
# Copy to .env and customize

# Database (SQLite for development, PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./hostingsignal.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/hostingsignal

# Security
SECRET_KEY=change-this-to-a-random-secret-key-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# License System
LICENSE_PREFIX=HS
LICENSE_VALIDATION_INTERVAL_HOURS=24
LICENSE_GRACE_PERIOD_DAYS=7

# CyberPanel Integration (optional)
# CYBERPANEL_URL=https://your-server:8090
# CYBERPANEL_API_KEY=your_api_key
# CYBERPANEL_ADMIN_USER=admin
# CYBERPANEL_ADMIN_PASS=your_password

# CORS
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# SMTP (for license emails)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your_app_password
# SMTP_FROM=noreply@hostingsignal.com
