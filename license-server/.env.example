# HostingSignal License Server Environment
APP_NAME=HostingSignal License Server
APP_VERSION=1.0.0
DEBUG=False
HOST=0.0.0.0
PORT=8443

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://hostingsignal:your_secure_password@localhost:5432/hostingsignal_licenses
DATABASE_SYNC_URL=postgresql://hostingsignal:your_secure_password@localhost:5432/hostingsignal_licenses

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT — CHANGE THESE IN PRODUCTION (use: openssl rand -hex 64)
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-64
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_LICENSE_TOKEN_EXPIRE_DAYS=365

# Master API Key — CHANGE IN PRODUCTION
MASTER_API_KEY=hs-master-key-change-in-production

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Encryption Key — CHANGE IN PRODUCTION (use: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=change-me-32-byte-key-for-fernet!
